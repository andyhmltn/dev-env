#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if git diff --cached --name-only | grep -q "config/corne.keymap\|keyboard/keymap-drawer.config.yaml"; then
  echo "Keymap changed -- regenerating keyboard SVG..."
  "$REPO_ROOT/keyboard/draw.sh"
  git add "$REPO_ROOT/keyboard/keymap.svg"
fi

if command -v vhs &>/dev/null && command -v ffmpeg &>/dev/null; then
  echo "Regenerating os TUI screenshot..."
  cd "$REPO_ROOT"
  cargo build --release -q 2>/dev/null
  vhs docs/screenshot.tape 2>/dev/null
  ffmpeg -y -sseof -0.1 -i docs/os-screenshot.gif -frames:v 1 docs/os-screenshot.png 2>/dev/null
  rm -f docs/os-screenshot.gif
  git add "$REPO_ROOT/docs/os-screenshot.png"
fi
